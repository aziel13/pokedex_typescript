{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "esnext",
    "module": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/**/*.ts",
    "node_modules/vitest/globals.d.ts",
    "node_modules/vitest/globals.d.ts",
    "node_modules/vitest/",
    "node_modules/jest/package.json"
  ],
  "exclude": ["node_modules"]
}